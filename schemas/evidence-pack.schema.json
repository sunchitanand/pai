{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pai.dev/schemas/evidence-pack.schema.json",
  "title": "EvidencePack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_of_change",
    "files_changed",
    "failure_signal",
    "root_cause",
    "validations_run",
    "results",
    "proof_of_restore",
    "prevention_added",
    "failures",
    "residual_risk",
    "remaining_uncertainty",
    "confidence",
    "next_best_step"
  ],
  "properties": {
    "summary_of_change": { "type": "string", "minLength": 1 },
    "files_changed": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "failure_signal": { "type": "string", "minLength": 1 },
    "root_cause": { "type": "string", "minLength": 1 },
    "validations_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result"],
        "properties": {
          "command": { "type": "string" },
          "result": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "harness_scenarios_touched": { "type": "array", "items": { "type": "string" } },
    "results": { "type": "array", "items": { "type": "string" } },
    "proof_of_restore": { "type": "string", "minLength": 1 },
    "prevention_added": { "type": "string", "minLength": 1 },
    "failures": { "type": "array", "items": { "type": "string" } },
    "residual_risk": { "type": "string", "minLength": 1 },
    "remaining_uncertainty": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "next_best_step": { "type": "string", "minLength": 1 }
  }
}
