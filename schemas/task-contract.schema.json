{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pai.dev/schemas/task-contract.schema.json",
  "title": "TaskContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "objective",
    "why_now",
    "work_mode",
    "trigger_signal",
    "restore_condition",
    "prevention_followup",
    "in_scope",
    "out_of_scope",
    "affected_systems",
    "success_criteria",
    "validations_required",
    "evidence_pack",
    "risks",
    "escalation_conditions"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "why_now": { "type": "string", "minLength": 1 },
    "status": { "type": "string" },
    "owner": { "type": "string" },
    "work_mode": { "type": "string", "enum": ["planned", "reactive"] },
    "trigger_signal": { "type": "string", "minLength": 1 },
    "restore_condition": { "type": "string", "minLength": 1 },
    "prevention_followup": { "type": "string", "minLength": 1 },
    "related_request": { "type": "string" },
    "in_scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "out_of_scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "affected_systems": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "success_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "validations_required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "checklists_required": { "type": "array", "items": { "type": "string" } },
    "decision_logs_expected": { "type": "array", "items": { "type": "string" } },
    "evidence_pack": { "type": "string", "minLength": 1 },
    "risks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "escalation_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
